# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# DomRent Backend API URL
DOMRENT_API_URL=http://localhost:5000/api

# Internal API key for backend→bot notifications (any random secret string)
BOT_API_KEY=your_secret_key_here

# Port for notification HTTP server (used by DomRent backend)
BOT_PORT=4000

# PostgreSQL connection string (same DB as backend or separate)
DATABASE_URL=postgresql://user:password@localhost:5432/domrent

# Comma-separated Telegram IDs of bot admins (get your ID via /start)
ADMIN_CHAT_IDS=123456789,987654321
