

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  LANDLORD
}

enum ContractType {
  RENT
  SALE
}

model City {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  properties Property[]
  createdAt  DateTime   @default(now())
}

model User {
  id         Int        @id @default(autoincrement())
  email      String     @unique
  password   String
  name       String?
  phone      String?
  telegramId String? 
  role       Role       @default(USER)
  properties Property[] // Жилье, которое сдает этот юзер
  bookings   Booking[]  // Бронирования этого юзера
  favorites  Favorite[]
  createdAt  DateTime   @default(now())
}

model Property {
  id           Int          @id @default(autoincrement())
  title        String
  description  String
  price        Float
  type         String       // квартира, дом, комната
  contractType ContractType @default(RENT) // RENT или SALE
  cityId       Int
  city         City         @relation(fields: [cityId], references: [id])
  images       String[]     // Массив ссылок на фото
  latitude     Float?       // Широта (DECIMAL-9,6 precision хранится как Float в Prisma)
  longitude    Float?       // Долгота
  ownerId      Int
  owner        User         @relation(fields: [ownerId], references: [id])
  bookings     Booking[]
  favorites    Favorite[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([latitude, longitude])
}

model Booking {
  id         Int      @id @default(autoincrement())
  startDate  DateTime
  endDate    DateTime
  totalPrice Float    // Вычисляется как (endDate - startDate) * property.price
  userId     Int
  propertyId Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Favorite {
  id         Int      @id @default(autoincrement())
  userId     Int
  propertyId Int
  user       User     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])
  @@unique([userId, propertyId]) // Чтобы нельзя было лайкнуть дважды
}
