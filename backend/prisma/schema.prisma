

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  LANDLORD
}

enum ContractType {
  RENT
  SALE
}

enum BookingStatus {
  UPCOMING    // Предстоящее
  ACTIVE      // Идёт прямо сейчас
  COMPLETED   // Завершено
  CANCELLED   // Отменено
}

model City {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  properties Property[]
  createdAt  DateTime   @default(now())
}

model User {
  id         Int        @id @default(autoincrement())
  email      String     @unique
  password   String
  name       String?
  phone      String?
  telegramId String? 
  role       Role       @default(USER)
  properties    Property[]
  bookings      Booking[]
  favorites     Favorite[]
  reviews       Review[]       @relation("ReviewAuthor")
  sentMessages  Message[]      @relation("MessageSender")
  notifications Notification[]
  createdAt     DateTime       @default(now())
}

model Property {
  id           Int          @id @default(autoincrement())
  title        String
  description  String
  price        Float
  type         String       // квартира, дом, комната
  contractType ContractType @default(RENT) // RENT или SALE
  cityId       Int
  city         City         @relation(fields: [cityId], references: [id])
  images       String[]     // Массив ссылок на фото (до 20 штук)
  coverImage   String?      // Главное фото (URL из массива images)
  latitude     Float?       // Широта (DECIMAL-9,6 precision хранится как Float в Prisma)
  longitude    Float?       // Долгота
  ownerId      Int
  owner        User         @relation(fields: [ownerId], references: [id])
  bookings     Booking[]
  favorites    Favorite[]
  reviews      Review[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([latitude, longitude])
}

model Booking {
  id         Int           @id @default(autoincrement())
  startDate  DateTime
  endDate    DateTime
  totalPrice Float
  status     BookingStatus @default(UPCOMING)
  userId     Int
  propertyId Int
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reviews    Review[]
  messages   Message[]
  createdAt  DateTime      @default(now())

  @@index([userId, status])
  @@index([propertyId, status])
}

model Favorite {
  id         Int      @id @default(autoincrement())
  userId     Int
  propertyId Int
  user       User     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])
  @@unique([userId, propertyId])
}

// ─── Отзывы ─────────────────────────────────────────────────────────────────

model Review {
  id         Int      @id @default(autoincrement())
  rating     Int      // 1–5 звёзд
  text       String
  authorId   Int
  propertyId Int
  bookingId  Int      @unique  // Один отзыв на одно бронирование
  author     User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([authorId, bookingId])
  @@index([propertyId])
}

// ─── Чат ────────────────────────────────────────────────────────────────────

model Message {
  id         Int      @id @default(autoincrement())
  text       String
  senderId   Int
  bookingId  Int
  isRead     Boolean  @default(false)
  sender     User     @relation("MessageSender", fields: [senderId], references: [id])
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([bookingId, createdAt])
}

// ─── In-app уведомления ──────────────────────────────────────────────────────

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  entityId  Int?             // ID связанного объекта (booking, message и т.д.)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
}

enum NotificationType {
  BOOKING_NEW        // Новое бронирование (для арендодателя)
  BOOKING_CONFIRMED  // Бронирование подтверждено
  BOOKING_CANCELLED  // Бронирование отменено
  MESSAGE_NEW        // Новое сообщение в чате
  REVIEW_NEW         // Новый отзыв
}
