

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  LANDLORD
  ADMIN
}

enum ContractType {
  RENT
  SALE
}

enum BookingStatus {
  UPCOMING    // Предстоящее
  ACTIVE      // Идёт прямо сейчас
  COMPLETED   // Завершено
  CANCELLED   // Отменено
}

enum ModerationStatus {
  PENDING    // На проверке (не видно в поиске)
  APPROVED   // Одобрено
  REJECTED   // Отклонено (с причиной)
}

model City {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  properties Property[]
  createdAt  DateTime   @default(now())
}

model User {
  id         Int        @id @default(autoincrement())
  email      String     @unique
  password   String
  name       String?
  phone      String?
  telegramId String?
  role       Role       @default(USER)
  isBanned   Boolean    @default(false)
  properties    Property[]
  bookings      Booking[]
  favorites     Favorite[]
  reviews       Review[]       @relation("ReviewAuthor")
  sentMessages  Message[]      @relation("MessageSender")
  notifications Notification[]
  createdAt     DateTime       @default(now())
}

model Property {
  id              Int              @id @default(autoincrement())
  title           String
  description     String
  price           Float
  type            String           // квартира, дом, комната
  contractType    ContractType     @default(RENT)
  rooms           Int?             // Количество комнат
  hasWifi         Boolean          @default(false)
  hasParking      Boolean          @default(false)
  petsAllowed     Boolean          @default(false)
  status          ModerationStatus @default(PENDING)
  rejectionReason String?          // Причина отклонения от админа
  cityId          Int
  city            City             @relation(fields: [cityId], references: [id])
  images          String[]
  coverImage      String?
  latitude        Float?
  longitude       Float?
  ownerId         Int
  owner           User             @relation(fields: [ownerId], references: [id])
  bookings        Booking[]
  favorites       Favorite[]
  reviews         Review[]
  blockedDates    BlockedDate[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([latitude, longitude])
  @@index([status])
}

model BlockedDate {
  id         Int      @id @default(autoincrement())
  propertyId Int
  date       DateTime @db.Date  // Только дата без времени
  reason     String?            // "booking" | "manual" | custom text
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([propertyId, date])
  @@index([propertyId])
}

model Booking {
  id         Int           @id @default(autoincrement())
  startDate  DateTime
  endDate    DateTime
  totalPrice Float
  status     BookingStatus @default(UPCOMING)
  userId     Int
  propertyId Int
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reviews    Review[]
  messages   Message[]
  createdAt  DateTime      @default(now())

  @@index([userId, status])
  @@index([propertyId, status])
}

model Favorite {
  id         Int      @id @default(autoincrement())
  userId     Int
  propertyId Int
  user       User     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])
  @@unique([userId, propertyId])
}

// ─── Отзывы ─────────────────────────────────────────────────────────────────

model Review {
  id         Int      @id @default(autoincrement())
  rating     Int      // 1–5 звёзд
  text       String
  authorId   Int
  propertyId Int
  bookingId  Int      @unique
  author     User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([authorId, bookingId])
  @@index([propertyId])
}

// ─── Чат ────────────────────────────────────────────────────────────────────

model Message {
  id         Int      @id @default(autoincrement())
  text       String
  senderId   Int
  bookingId  Int
  isRead     Boolean  @default(false)
  sender     User     @relation("MessageSender", fields: [senderId], references: [id])
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([bookingId, createdAt])
}

// ─── In-app уведомления ──────────────────────────────────────────────────────

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  entityId  Int?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
}

enum NotificationType {
  BOOKING_NEW
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  MESSAGE_NEW
  REVIEW_NEW
  PROPERTY_APPROVED
  PROPERTY_REJECTED
}
